# Application
APP_NAME=Euro Park API
APP_SERVICE_NAME = euro-park-api
APP_VERSION = 0.1.0
APP_ENV=development
APP_DEBUG=true

# API
API_V1_PREFIX=/api/v1

# SQL Server container bootstrap
MSSQL_SA_PASSWORD=SaPassword123!

# SQL Server
DB_HOST=localhost
DB_PORT=14333
DB_NAME=euro_park
DB_USER=euro_park_app
DB_PASSWORD=AppPassword123!

# ODBC
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true


# JWT
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ISSUER=euro-park-api
JWT_AUDIENCE=euro-park-client
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# Rate limiting
RATE_LIMIT_ENABLED=true
BARRIER_RATE_LIMIT_REQUESTS=60
BARRIER_RATE_LIMIT_WINDOW_SECONDS=6